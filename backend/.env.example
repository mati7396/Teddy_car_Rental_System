# Database Configuration (PostgreSQL)
# Format: postgresql://username:password@localhost:5432/database_name?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/teddy_car_rental?schema=public"

# JWT Secret - Change this in production!
JWT_SECRET="your_jwt_secret_key_here"

# Server Port
PORT=5000

# Frontend URL (for CORS configuration)
FRONTEND_URL="http://localhost:5173"

# SMTP settings for email delivery
# If left as placeholder values, backend will fallback to an Ethereal test inbox.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_SECURE="false"
EMAIL_FROM="no-reply@teddyrental.com"

# Chapa payment gateway secret key
CHAPA_SECRET_KEY="your_key_here"
